# pins.env - ALL version/commit/image pins for tools/build_native_libraries.
# Edit here only; build.sh and container_build.sh both source this file.
#
# Sources of truth inside this repo:
#   opencv / opencv_contrib commits:  native_src/README-NATIVE-SRC.txt
#     (the exact submodule revisions the shipped upstream natives were built from)
#   vcpkg baseline:                   native_src/vcpkg.json (builtin-baseline)
#   FFmpeg version:                   native_src/docker/manylinux/build_static_deps.sh
#   OpenCV version:                   native_src/ci-workflows/manylinux.yml (env)
#   container image names:            README.txt ARCHITECTURE MATRIX

# --- Container images (quay.io/pypa manylinux; dated tags verified present
#     2026-07-22, digest of each recorded beside it for provenance) ---
IMAGE_X64=quay.io/pypa/manylinux_2_28_x86_64:2026.07.19-1
#   sha256:a61875a2f84cab7df8de222ff12cabc08ff86eb4ad402ac90ba7bdaed9600cca
IMAGE_ARM64=quay.io/pypa/manylinux_2_28_aarch64:2026.07.19-1
#   sha256:162c81dfd3efc710732a571717d3c916a6945ebf279e879ddee3243af96fe46f
IMAGE_RISCV64=quay.io/pypa/manylinux_2_39_riscv64:2026.07.19-1
#   sha256:04b3acc69a6cebb10ac1252587d202acce6445d91c783d3f92229bb2b2483069

# --- OpenCV (pinned to the exact revisions the shipped upstream natives
#     were built from; see native_src/README-NATIVE-SRC.txt) ---
OPENCV_VERSION=5.0.0
OPENCV_REPO=https://github.com/opencv/opencv.git
OPENCV_COMMIT=40738fb16ceddb5fb3fea747585f7ce6abb0605b
OPENCV_CONTRIB_REPO=https://github.com/opencv/opencv_contrib.git
OPENCV_CONTRIB_COMMIT=755e50675d97db9b7d449d8bd6b09888646f6c6e

# --- vcpkg (the repo is checked out AT the manifest's builtin-baseline
#     commit, so the tool and the baseline always agree) ---
VCPKG_REPO=https://github.com/microsoft/vcpkg.git
VCPKG_COMMIT=1e199d32ad53aab1defda61ce41c380302e3f95c

# --- FFmpeg (built static from source; same version and configure flags as
#     upstream's native_src/docker/manylinux/build_static_deps.sh) ---
FFMPEG_VERSION=7.1.1
